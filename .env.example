# Qdrant connection
# URL of your Qdrant instance (e.g., https://xyz.cloud.qdrant.io or http://localhost:6333)
QDRANT_URL=

# Qdrant API key (required for Qdrant Cloud; leave empty for local unauthenticated instances)
QDRANT_API_KEY=

# Embeddings provider (optional, defaults to "openai")
# Valid values: openai | voyage | cohere | ollama
EMBEDDINGS_PROVIDER=openai

# API key for the embeddings provider
# For OpenAI: your OpenAI API key
# For Voyage AI: your Voyage API key
# For Cohere: your Cohere API key
# For Ollama: leave empty (uses local URL below)
EMBEDDINGS_API_KEY=

# Base URL for Ollama (only required when EMBEDDINGS_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# Enable verbose debug logging to stderr
# MEMO_DEBUG=true
